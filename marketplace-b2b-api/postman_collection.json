    {
      "name": "02. Commission Categories (admin)",
      "item": [
        {
          "name": "Crear categoria de comision",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var data = pm.response.json();",
                  "  pm.collectionVariables.set('commissionCategoryId', data.id);",
                  "} else if (pm.response.code === 409) {",
                  "  pm.sendRequest({",
                  "    url: pm.collectionVariables.get('baseUrl') + '/commission-categories',",
                  "    method: 'GET',",
                  "    header: { Authorization: 'Bearer ' + pm.collectionVariables.get('adminToken') }",
                  "  }, function (err, res) {",
                  "    if (!err && res.code === 200) {",
                  "      var categories = res.json();",
                  "      var existing = categories.find(function(c) { return c.name === 'Materiales de construccion'; });",
                  "      if (existing) { pm.collectionVariables.set('commissionCategoryId', existing.id); }",
                  "    }",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/commission-categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Materiales de construccion\",\n  \"commissionPercentage\": 8.5\n}"
            }
          }
        },
        {
          "name": "Listar categorias",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/commission-categories"
          }
        }
      ]
    },
    {
      "name": "03. Products (proveedor)",
      "item": [
        {
          "name": "Crear producto con rangos de precio",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('productId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Varilla de acero corrugado 3/8\\\"\",\n  \"description\": \"Varilla de acero corrugado grado 60, 6 metros\",\n  \"basePrice\": 8.75,\n  \"totalStock\": 5000,\n  \"commissionCategoryId\": \"{{commissionCategoryId}}\",\n  \"priceRanges\": [\n    { \"minQuantity\": 1, \"maxQuantity\": 99, \"unitPrice\": 8.75 },\n    { \"minQuantity\": 100, \"maxQuantity\": 499, \"unitPrice\": 7.9 },\n    { \"minQuantity\": 500, \"maxQuantity\": null, \"unitPrice\": 6.95 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar productos (catalogo)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{buyerToken}}"
              }
            ],
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Listar solo mis productos (?providerId=)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/products?providerId={{providerId}}"
          }
        }
      ]
    },
    {
      "name": "04. Flujo de Cotizacion",
      "item": [
        {
          "name": "1. Comprador solicita cotizacion",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('quoteRequestId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{buyerToken}}"
              }
            ],
            "url": "{{baseUrl}}/quotes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"requestedQuantity\": 150,\n  \"notes\": \"Necesito entrega la proxima semana\"\n}"
            }
          }
        },
        {
          "name": "2. Proveedor responde (precio automatico)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/quotes/{{quoteRequestId}}/respond",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerNotes\": \"Precio calculado segun volumen\"\n}"
            }
          }
        },
        {
          "name": "3. Comprador acepta (genera orden automaticamente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('orderId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{buyerToken}}"
              }
            ],
            "url": "{{baseUrl}}/quotes/{{quoteRequestId}}/accept"
          }
        }
      ]
    },
    {
      "name": "05. Flujo de Orden",
      "item": [
        {
          "name": "Ver orden generada",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{buyerToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Proveedor confirma orden (descuenta stock)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmada\"\n}"
            }
          }
        },
        {
          "name": "Proveedor marca en preparacion",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"en_preparacion\"\n}"
            }
          }
        },
        {
          "name": "Proveedor marca despachada",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"despachada\"\n}"
            }
          }
        },
        {
          "name": "Proveedor marca recibida (completa el ciclo)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"recibida\"\n}"
            }
          }
        }
      ]
    },
    {
