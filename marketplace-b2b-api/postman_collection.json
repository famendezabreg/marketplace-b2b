            "url": "{{baseUrl}}/settlements",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"providerId\": \"{{providerId}}\",\n  \"periodStart\": \"2020-01-01\",\n  \"periodEnd\": \"2030-01-01\"\n}"
            }
          }
        },
        {
          "name": "Ver liquidacion generada",
          "request": {
            "method": "GET",
            "header": [
