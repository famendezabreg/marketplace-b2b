                  "  pm.collectionVariables.set('providerToken', data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"proveedor@demo.com\",\n  \"password\": \"Proveedor123\",\n  \"role\": \"proveedor\",\n  \"companyName\": \"Distribuidora ACME S.A.\",\n  \"taxId\": \"0614-123456-001-2\",\n  \"phone\": \"+503 7000-0000\"\n}"
