{
  "info": {
    "name": "Marketplace B2B API",
    "description": "Flujo completo: registro -> catalogo -> cotizacion -> orden -> liquidacion. Los tokens e IDs se guardan automaticamente entre pasos (scripts en cada request), no requiere copiar/pegar nada manualmente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "providerToken",
      "value": ""
    },
    {
      "key": "buyerToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "providerId",
      "value": ""
    },
    {
      "key": "buyerId",
      "value": ""
    },
    {
      "key": "commissionCategoryId",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "quoteRequestId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "settlementId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01. Auth",
      "item": [
